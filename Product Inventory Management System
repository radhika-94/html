Product Inventory Management System

Serial_number:Number,ManuFature_Date:Date,Expiry_Date:Date,ProductName(already)



Aperx Class:

public class ProductController {



    public Product_Inventory__c prod {get; set;}

    public List<Product_Inventory__c> productList {get; set;}



    // Constructor

    public ProductController() {



        prod = new Product_Inventory__c();



        loadProducts();

    }



    // Save Product

    public void saveProduct() {



        insert prod;



        prod = new Product_Inventory__c();



        loadProducts();

    }



    // Load Products

    public void loadProducts() {



        productList = [SELECT Id,

                       Name,

                       Serial_Number__c,

                       Manufacture_Date__c,

                       Expiry_Date__c

                       FROM Product_Inventory__c];

    }

}

visualforce Page:
<apex:page controller="ProductController">



  <apex:form>



    <apex:pageBlock title="Product Inventory Management System">



      <apex:pageBlockSection columns="1">



        <apex:inputText value="{!prod.Name}"

                label="Product Name"/>



        <apex:inputText value="{!prod.Serial_No__c}"

                label="Serial No"/>



        <apex:inputField value="{!prod.Manufacture_Date__c}"

                 label="Manufacture Date"/>



        <apex:inputField value="{!prod.Expiry_Date__c}"

                 label="Expiry Date"/>



      </apex:pageBlockSection>



      <apex:commandButton value="Save Product"

                action="{!saveProduct}"/>



    </apex:pageBlock>



    <br/>



    <apex:pageBlock title="Product Records">



      <apex:pageBlockTable value="{!productList}"

                 var="p">



        <apex:column value="{!p.Name}"

               headerValue="Product Name"/>



        <apex:column value="{!p.Serial_No__c}"

               headerValue="Serial No"/>



        <apex:column value="{!p.Manufacture_Date__c}"

               headerValue="Manufacture Date"/>



        <apex:column value="{!p.Expiry_Date__c}"

               headerValue="Expiry Date"/>



      </apex:pageBlockTable>



    </apex:pageBlock>



  </apex:form>



</apex:page>

